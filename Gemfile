source 'https://rubygems.org'

# 锁定 Jekyll 版本，与 GitHub Pages 保持一致
gem 'jekyll', '~> 3.9.0'

# 必需的插件（与 _config.yml 中的 plugins 对应）
gem 'jekyll-remote-theme'
gem 'jemoji'
gem 'jekyll-relative-links'

# 主题依赖（minimal 主题需要）
gem 'jekyll-seo-tag'
gem 'jekyll-sitemap'

# Ruby 3.0+ 需要 webrick
gem 'webrick', '~> 1.8'
